        "prisma:studio": "prisma studio"
    },
    "keywords": [
        "nodejs",
        "express",
        "typescript",
        "prisma",
        "postgresql",
        "zod",
        "rest-api",
        "games",
        "game-library",
        "backend",
        "portfolio",
        "clean-architecture"
    ],
