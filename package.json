{
    "name": "game-codex-api",
    "version": "1.0.0",
    "description": "REST API focused on game discovery and search, featuring filtering by genres, platforms, studios, classifications and release dates.",
    "main": "index.js",
    "scripts": {
        "start:dev": "tsx watch --env-file=.env src/server.ts",
