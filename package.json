    "license": "ISC",
    "type": "module",
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.20.0",
        "prisma": "^7.8.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "pg": "^8.20.0",
        "zod": "^4.3.6"
